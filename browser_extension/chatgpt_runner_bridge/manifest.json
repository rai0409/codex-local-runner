{
  "manifest_version": 3,
  "name": "ChatGPT Runner Bridge",
  "version": "0.1.0",
  "description": "One-click bridge from logged-in ChatGPT tab to local runner server.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*",
    "http://172.25.238.255:8765/*"
  ],
  "action": {
    "default_title": "Run ChatGPT Bridge"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
